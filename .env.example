# Claude API
ANTHROPIC_API_KEY=your-api-key-here

# Project repos to scan (comma-separated absolute paths)
PROJECT_REPOS=/Users/you/Claude_Projects/insight-clips,/Users/you/Claude_Projects/metrics-agent,/Users/you/Claude_Projects/competitive-analysis

# Telegram notifications (optional — get these from @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# Output directory (default: ./output)
OUTPUT_DIR=./output
